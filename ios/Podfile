platform :ios, '13.0'

# A standalone Podfile that doesn't rely on podhelper.rb for CI stability
# This manually points to the Flutter engine and plugins

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Injected via git push to ensure CI has access
  # flutter_install_all_ios_pods is a macro that we can bypass if we force-link plugins
  # But since we fixed the git push, we can try the normal way one last time with a SAFE LOAD
  
  podhelper_path = File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')
  if File.exist?(podhelper_path)
    load podhelper_path
    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end
